{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "description": "VW Boble 1956 — Drag-analyse. RPM, hastighet, AFR og split-tider under drag-kjøring.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "id": 1,
      "title": "RPM og Hastighet — drag-kjøring",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "rpm" },
            "properties": [
              { "id": "displayName", "value": "Turtall (RPM)" },
              { "id": "color", "value": { "fixedColor": "#00C8FF", "mode": "fixed" } },
              { "id": "unit", "value": "rotrpm" },
              { "id": "custom.axisPlacement", "value": "left" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "speed" },
            "properties": [
              { "id": "displayName", "value": "Hastighet" },
              { "id": "color", "value": { "fixedColor": "#a8ff3e", "mode": "fixed" } },
              { "id": "unit", "value": "velocitykmh" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"sensordata\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"sensordata\") |> filter(fn: (r) => r._field == \"rpm\" or r._field == \"speed\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "AFR under kjøring (lambda)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 16, "x": 0, "y": 9 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0.7, "max": 1.3,
          "color": { "fixedColor": "#ffaa00", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.85 },
              { "color": "green", "value": 0.95 },
              { "color": "yellow", "value": 1.05 },
              { "color": "red", "value": 1.1 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "hidden" }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"sensordata\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"sensordata\" and r._field == \"lambda\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "CHT under kjøring",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 9 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 220 },
              { "color": "red", "value": 260 }
            ]
          },
          "custom": { "lineWidth": 1.5 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"sensordata\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"sensordata\") |> filter(fn: (r) => r._field == \"cht1\" or r._field == \"cht2\" or r._field == \"cht3\" or r._field == \"cht4\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Drag-historikk — split-tider",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "dato" }, "properties": [{ "id": "unit", "value": "none" }] },
          { "matcher": { "id": "byName", "options": "topphastighet" }, "properties": [{ "id": "unit", "value": "velocitykmh" }] }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "dato", "desc": true }]
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"sensordata\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"drag_events\") |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["vw-boble", "drag", "racing"],
  "time": { "from": "now-30m", "to": "now" },
  "timezone": "browser",
  "title": "VW Boble — Drag Analyse",
  "uid": "vw-drag-analyse",
  "version": 1
}
